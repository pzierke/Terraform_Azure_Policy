## 6) `initiative.tf`

```hcl
resource "azurerm_management_group_policy_set_definition" "cis_foundations_v5" {
  name                = var.initiative_name
  management_group_id = var.management_group_id
  policy_type         = "Custom"
  display_name        = var.initiative_display_name
  description         = var.initiative_description

  metadata = jsonencode({
    category = "CIS"
    version  = "5.0"
    source   = "Terraform"
  })

  parameters = jsonencode({
    effect = {
      type = "String"
      metadata = {
        displayName = "Default Effect"
        description = "Default effect for custom CIS policies."
      }
      allowedValues = ["Audit", "Deny", "Disabled"]
      defaultValue  = var.policy_effect_default
    }
  })

  dynamic "policy_definition_reference" {
    for_each = local.initiative_policy_definitions

    content {
      policy_definition_id = policy_definition_reference.value.policy_definition_id
      reference_id         = policy_definition.value.reference_id
      parameter_values     = jsonencode(policy_definition_reference.value.parameters)
    }
  }
}
```

Important fix here: in some provider versions, the dynamic block variable naming matters. If Terraform complains, use this corrected version instead:

```hcl
resource "azurerm_management_group_policy_set_definition" "cis_foundations_v5" {
  name                = var.initiative_name
  management_group_id = var.management_group_id
  policy_type         = "Custom"
  display_name        = var.initiative_display_name
  description         = var.initiative_description

  metadata = jsonencode({
    category = "CIS"
    version  = "5.0"
    source   = "Terraform"
  })

  parameters = jsonencode({
    effect = {
      type = "String"
      metadata = {
        displayName = "Default Effect"
        description = "Default effect for custom CIS policies."
      }
      allowedValues = ["Audit", "Deny", "Disabled"]
      defaultValue  = var.policy_effect_default
    }
  })

  dynamic "policy_definition_reference" {
    for_each = local.initiative_policy_definitions

    content {
      policy_definition_id = policy_definition_reference.value.policy_definition_id
      reference_id         = policy_definition_reference.value.reference_id
      parameter_values     = jsonencode(policy_definition_reference.value.parameters)
    }
  }
}
```

Use that second version.

