## 5) `custom_policy_definitions.tf`

These are example custom policies. They are not a complete CIS v5.0 implementation, but they show the pattern cleanly.

```hcl
resource "azurerm_management_group_policy_definition" "storage_accounts_secure_transfer" {
  name                 = "cis-custom-storage-accounts-secure-transfer-required"
  management_group_id  = var.management_group_id
  policy_type          = "Custom"
  mode                 = "Indexed"
  display_name         = "CIS Custom - Storage accounts should require secure transfer"
  description          = "Audits or denies storage accounts that do not require secure transfer."
  metadata             = jsonencode({
    category = "CIS"
    version  = "5.0"
    source   = "Custom"
  })

  parameters = jsonencode({
    effect = {
      type         = "String"
      metadata     = {
        displayName = "Effect"
        description = "Enable or disable the execution of the policy."
      }
      allowedValues = ["Audit", "Deny", "Disabled"]
      defaultValue  = "Audit"
    }
  })

  policy_rule = jsonencode({
    if = {
      allOf = [
        {
          field  = "type"
          equals = "Microsoft.Storage/storageAccounts"
        },
        {
          field  = "Microsoft.Storage/storageAccounts/supportsHttpsTrafficOnly"
          notEquals = true
        }
      ]
    }
    then = {
      effect = "[parameters('effect')]"
    }
  })
}

resource "azurerm_management_group_policy_definition" "sql_servers_aad_admin" {
  name                 = "cis-custom-sql-servers-should-have-aad-admin"
  management_group_id  = var.management_group_id
  policy_type          = "Custom"
  mode                 = "All"
  display_name         = "CIS Custom - SQL servers should have an Azure AD administrator configured"
  description          = "Audits SQL servers that do not have an Azure AD administrator configured."
  metadata             = jsonencode({
    category = "CIS"
    version  = "5.0"
    source   = "Custom"
  })

  parameters = jsonencode({
    effect = {
      type         = "String"
      metadata     = {
        displayName = "Effect"
        description = "Enable or disable the execution of the policy."
      }
      allowedValues = ["Audit", "Deny", "Disabled"]
      defaultValue  = "Audit"
    }
  })

  policy_rule = jsonencode({
    if = {
      allOf = [
        {
          field  = "type"
          equals = "Microsoft.Sql/servers"
        },
        {
          count = {
            field = "Microsoft.Sql/servers/administrators[*]"
            where = {
              field  = "Microsoft.Sql/servers/administrators[*].administratorType"
              equals = "ActiveDirectory"
            }
          }
          equals = 0
        }
      ]
    }
    then = {
      effect = "[parameters('effect')]"
    }
  })
}
```

