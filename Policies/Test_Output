## 3) `variables.tf`

```hcl
variable "management_group_id" {
  description = "The Azure Management Group ID where policies and initiative will be created."
  type        = string
}

variable "management_group_display_name" {
  description = "Optional display name for documentation/tagging purposes."
  type        = string
  default     = null
}

variable "location" {
  description = "Azure location for assignment identity/resources where needed."
  type        = string
  default     = "eastus"
}

variable "initiative_name" {
  description = "Name of the custom CIS initiative."
  type        = string
  default     = "cis-azure-foundations-v5-custom"
}

variable "initiative_display_name" {
  description = "Display name of the custom initiative."
  type        = string
  default     = "CIS Azure Foundations Benchmark v5.0 - Custom"
}

variable "initiative_description" {
  description = "Description for the custom initiative."
  type        = string
  default     = "Custom Azure Policy initiative aligned to CIS Microsoft Azure Foundations Benchmark v5.0."
}

variable "assignment_name" {
  description = "Name of the management group assignment."
  type        = string
  default     = "assign-cis-azure-foundations-v5-custom"
}

variable "assignment_display_name" {
  description = "Display name for the initiative assignment."
  type        = string
  default     = "Assign CIS Azure Foundations Benchmark v5.0 - Custom"
}

variable "assignment_description" {
  description = "Description for the initiative assignment."
  type        = string
  default     = "Assigns the custom CIS Azure Foundations Benchmark v5.0 initiative at the management group scope."
}

variable "enforcement_mode" {
  description = "Whether policy effects are enforced. Default enables enforcement."
  type        = bool
  default     = true
}

variable "policy_effect_default" {
  description = "Default effect to use for custom policies where effect is parameterized."
  type        = string
  default     = "Audit"

  validation {
    condition     = contains(["Audit", "Deny", "Disabled"], var.policy_effect_default)
    error_message = "policy_effect_default must be one of: Audit, Deny, Disabled."
  }
}

variable "tags" {
  description = "Optional tags/metadata map for documentation purposes."
  type        = map(string)
  default     = {}
}
```

