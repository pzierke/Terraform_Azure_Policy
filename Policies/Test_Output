## 4) `locals.tf`

This is where we model the initiative membership.

```hcl
locals {
  management_group_scope = "/providers/Microsoft.Management/managementGroups/${var.management_group_id}"

  /*
    Starter set only.
    Replace the built-in definition IDs below with the exact policies you want
    after validating your CIS v5.0 control mapping.

    Best practice:
    - keep this list small and verified
    - add policies incrementally
    - test assignments in a non-production management group first
  */
  built_in_policy_definitions = {
    # Example placeholders. Replace with validated built-in definition IDs.
    allowed_locations = {
      reference_id = "allowedLocations"
      policy_definition_id = "/providers/Microsoft.Authorization/policyDefinitions/PLACEHOLDER-ALLOWED-LOCATIONS"
      parameters = {
        listOfAllowedLocations = {
          value = ["eastus", "eastus2"]
        }
      }
    }

    require_resource_tags = {
      reference_id = "requireResourceTags"
      policy_definition_id = "/providers/Microsoft.Authorization/policyDefinitions/PLACEHOLDER-REQUIRE-TAGS"
      parameters = {}
    }
  }

  custom_policy_definitions = {
    storage_accounts_secure_transfer = {
      reference_id = "storageAccountsSecureTransfer"
      policy_definition_id = azurerm_management_group_policy_definition.storage_accounts_secure_transfer.id
      parameters = {
        effect = {
          value = var.policy_effect_default
        }
      }
    }

    sql_servers_aad_admin = {
      reference_id = "sqlServersAadAdmin"
      policy_definition_id = azurerm_management_group_policy_definition.sql_servers_aad_admin.id
      parameters = {
        effect = {
          value = var.policy_effect_default
        }
      }
    }
  }

  initiative_policy_definitions = merge(
    local.built_in_policy_definitions,
    local.custom_policy_definitions
  )
}
```

