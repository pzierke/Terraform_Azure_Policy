## 7) `assignment.tf`

```hcl
resource "azurerm_management_group_policy_assignment" "cis_foundations_v5_assignment" {
  name                 = var.assignment_name
  display_name         = var.assignment_display_name
  description          = var.assignment_description
  management_group_id  = var.management_group_id
  policy_definition_id = azurerm_management_group_policy_set_definition.cis_foundations_v5.id
  location             = var.location
  enforce              = var.enforcement_mode

  identity {
    type = "SystemAssigned"
  }

  parameters = jsonencode({
    effect = {
      value = var.policy_effect_default
    }
  })

  metadata = jsonencode({
    assignedBy = "Terraform"
    benchmark  = "CIS Microsoft Azure Foundations Benchmark"
    version    = "5.0"
  })
}
```

